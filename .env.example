# ─── Zalo / OpenZCA ───────────────────────────────────────────────────────────
OPENZCA_PROFILE=default
OPENZCA_BIN=openzca
# OWN_ID=715603102114017070  # Auto-detected if empty

# ─── Hermes Bridge ────────────────────────────────────────────────────────────
HERMES_API_URL=http://localhost:5000/chat
HERMES_API_KEY=
HERMES_TIMEOUT=60

# ─── SQLite ───────────────────────────────────────────────────────────────────
SQLITE_PATH=~/.beargate/beargate.db

# ─── MariaDB ──────────────────────────────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=beargate
MARIADB_PASSWORD=your_password_here
MARIADB_DATABASE=beargate

# ─── Auto-Sync ────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
