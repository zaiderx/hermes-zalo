# ─── Zalo / OpenZCA (multi-account) ───────────────────────────────────────────
OPENZCA_BIN=openzca

# Multi-account: comma-separated profile names
# Each profile = one Zalo account
OPENZCA_PROFILES=personal,work
# Or single profile:
# OPENZCA_PROFILE=personal

# Per-profile config (optional, JSON):
# PROFILES_CONFIG={"personal": {"label": "Cá nhân"}, "work": {"label": "Công việc"}}

# Legacy single profile (auto-detected if not set):
# OWN_ID=715603102114017070

# ─── Hermes Bridge ────────────────────────────────────────────────────────────
HERMES_API_URL=http://localhost:5000/chat
HERMES_API_KEY=
HERMES_TIMEOUT=60

# ─── SQLite ───────────────────────────────────────────────────────────────────
SQLITE_PATH=~/.hermes-zalo/hermes-zalo.db

# ─── MariaDB ──────────────────────────────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=hermes-zalo
MARIADB_PASSWORD=your_password_here
MARIADB_DATABASE=hermes-zalo

# ─── Auto-Sync ────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
